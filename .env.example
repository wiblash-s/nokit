# Defuse environment
# Copy to .env and fill in. Never commit .env.

# ---- Panel auth ----
# Authentication mode: "local" (single shared password, default) or "oidc"
# (OpenID Connect via an IdP such as Authelia backed by lldap). See the
# "Authentication" section of the README for full setup instructions.
AUTH_MODE=local

# Set to "1" only when serving the panel over plain HTTP (e.g. local dev).
# Leave unset in production so the session/state cookies are marked Secure.
AUTH_COOKIE_INSECURE=

# --- Local mode (AUTH_MODE=local) ---
# Required in local mode. Refuses to start if PANEL_PASSWORD is unset or matches
# a known weak default. This single account is granted all permissions.
PANEL_USERNAME=admin
PANEL_PASSWORD=

# --- OIDC mode (AUTH_MODE=oidc) ---
# Issuer URL of your IdP (Authelia). The panel discovers endpoints from
# <OIDC_ISSUER_URL>/.well-known/openid-configuration at startup, so it must be
# reachable by the panel.
OIDC_ISSUER_URL=https://auth.example.com
#
# OAuth2 client credentials, as registered with the IdP for this panel. The
# secret must be the PLAINTEXT value (Authelia stores its hash).
OIDC_CLIENT_ID=cs2rcon
OIDC_CLIENT_SECRET=
#
# Public URL the IdP redirects back to after login. Must exactly match one of
# the redirect_uris registered with the IdP. Path is "/api/auth/callback".
OIDC_REDIRECT_URL=https://rcon.example.com/api/auth/callback
#
# Optional. Space-separated OAuth2 scopes. Must include "openid"; "groups" is
# required for role mapping (Authelia emits group membership in the groups
# claim). Defaults to "openid profile email groups".
# OIDC_SCOPES=openid profile email groups
#
# Optional. Where the IdP sends the user after RP-initiated logout. Defaults to
# the app root derived from OIDC_REDIRECT_URL.
# OIDC_POST_LOGOUT_REDIRECT_URL=https://rcon.example.com/login

# ---- CS2 server: codevski-cs2 ----
# RCON password for this server. The env var name is RCON_PASSWORD_<UPPERCASE_SERVER_ID>,
# with hyphens converted to underscores.
RCON_PASSWORD=

# Steam Game Server Login Token. Required for the CS2 dedicated server to be public.
# Generate one at https://steamcommunity.com/dev/managegameservers (App ID: 730).
# Only needed if you're running the CS2 container from this compose file.
STEAM_GSLT=

# ---- Steam Workshop map thumbnails ----
# Steam Web API key. When set, the panel resolves each installed workshop map's
# preview image via the Steam Web API and caches it on disk, so the Maps page
# shows real thumbnails instead of placeholder gradients. Leave empty to disable
# thumbnails (the UI falls back to gradients). Get a key at:
# https://steamcommunity.com/dev/apikey
# NOTE: this is distinct from STEAM_GSLT above — GSLT makes the game server
# public; STEAM_API_KEY is only used by the panel to fetch workshop metadata.
STEAM_API_KEY=
#
# Directory where downloaded map thumbnails are cached. Optional; defaults to
# "thumbnails" relative to the panel's working directory. Each image is fetched
# from Steam at most once and then served from this cache.
THUMBNAIL_CACHE_DIR=thumbnails

# ---- Live Logs (UDP ingestion) ----
# Live Logs are received over UDP using CS2's built-in `logaddress_add`
# mechanism — no Docker socket required.
#
# UDP port the panel binds to receive CS2 logs. Must match the published port
# in docker-compose.yml and the port in CS2_LOG_SINK_ADDR. Default: 27500.
CS2_LOG_LISTEN_PORT=27500
#
# Address the CS2 server should send its logs to, as reachable *from the CS2
# container*. On startup the panel issues `logaddress_add <addr>; log on` over
# RCON so the server streams its console here. In the bundled docker-compose
# stack this is the panel's service name on the shared network. Leave empty to
# configure logaddress yourself in the CS2 server instead.
CS2_LOG_SINK_ADDR=defuse:27500

# ---- Live Logs (HTTP ingestion) ----
# Some CS2 servers deliver logs over HTTP via `logaddress_add_http <url>` instead
# of (or alongside) UDP. The panel exposes a public endpoint at
# `POST /api/logs/http` that feeds these lines into the same Live Logs pipeline
# as the UDP listener. Both transports can be used simultaneously.
#
# Full URL of the HTTP log endpoint, as reachable *from the CS2 container*. When
# set, the panel issues `logaddress_add_http <url>; log on` over RCON on startup.
# Leave empty to run `logaddress_add_http` yourself in the CS2 server.
CS2_LOG_HTTP_SINK_URL=http://defuse:8080/api/logs/http
#
# Optional shared secret. When set, the HTTP log endpoint requires a matching
# token via `?token=<secret>` query param or `X-Log-Token` header. Leave empty to
# leave the endpoint open. If set, include it in CS2_LOG_HTTP_SINK_URL, e.g.
# http://defuse:8080/api/logs/http?token=mysecret
CS2_LOG_HTTP_TOKEN=
